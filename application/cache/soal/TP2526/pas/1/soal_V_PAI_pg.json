        "kelas_cls": "V",
        "matapel_cls": "PAI",
        "jenis_penilaian": "pas",
        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Berikut ini pernyataan yang berkaitan dengan kota Makkah adalah...<\/p>",
        "jawaban_a": "<p>Tempat dilahirkanya Nabi Ibrahim dan Ismail<\/p>",
        "jawaban_b": "<p>Kota suci yang terdapat makan Nabi Muhammad<\/p>",
        "jawaban_c": "<p>Kota suci dan terdapat bangunan suci Masjidil Haram<\/p>",
        "jawaban_d": "<p>Tempat suci dan sebagai ibu kota Negara Arab Saudi<\/p>",
        "jawaban_e": null,
        "kunci_jawaban": "c",
        "img_path": null,
