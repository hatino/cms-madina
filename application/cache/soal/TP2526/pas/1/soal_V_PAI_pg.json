        "jenis_penilaian": "pas",
        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Perhatikan Q.S. Al-Baqarah : 255 berikut!<\/p><p><span class=\"text-huge\" style=\"font-family:Arial, Helvetica, sans-serif;\"><strong>\u0627\u064e\u0644\u0644\u0651\u0670\u0647\u064f \u0644\u064e\u0627\u0653 \u0627\u0650\u0644\u0670\u0647\u064e \u0627\u0650\u0644\u0651\u064e\u0627 \u0647\u064f\u0648\u064e\u06da \u0627\u064e\u0644\u0652\u062d\u064e\u064a\u0651\u064f \u0627\u0644\u0652\u0642\u064e\u064a\u0651\u064f\u0648\u0652\u0645\u064f \u06d5\u06da<\/strong><\/span><\/p><p>Ayat tersebut menunjukkan asmaulhusna...<\/p>",
        "jawaban_a": "<p>Al-Qayyum<\/p>",
        "jawaban_b": "<p>Al-Mumit<\/p>",
        "jawaban_c": "<p>Al-Ba`is<\/p>",
        "jawaban_d": "<p>Al-Muhyi<\/p>",
        "jawaban_e": null,
        "kunci_jawaban": "a",
