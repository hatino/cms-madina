        "matapel_cls": "PAI",
        "jenis_penilaian": "pas",
        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Haji yang dilaksanakan terakhir oleh Rasulullah kemudian berpidato di Arafah dikenal dengan nama...<\/p>",
        "jawaban_a": "<p>Haji Qiran<\/p>",
        "jawaban_b": "<p>Haji Tamatu<\/p>",
        "jawaban_c": "<p>Haji Ifrad<\/p>",
        "jawaban_d": "<p>Haji Wada<\/p>",
        "jawaban_e": null,
