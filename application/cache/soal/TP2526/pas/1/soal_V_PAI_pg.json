        "no_kd": null,
        "pertanyaan": "<p>Pernyataan yang sesuai dengan asmaulhusna <i>Al-Baist<\/i> adalah...<\/p>",
        "jawaban_a": "<p>Allah menghidupkan bayi dalam kandungan<\/p>",
        "jawaban_b": "<p>Allah akan membangkitkan manusia dari alam kubur<\/p>",
        "jawaban_c": "<p>Allah maha menguasai seluruh alam semesta<\/p>",
        "jawaban_d": "<p>Allah akan menumbuhkan rumput-rumputan yang telah kering<\/p>",
