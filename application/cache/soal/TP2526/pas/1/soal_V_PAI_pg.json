        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Allah memerintahkan kepada muslim untuk meneladani para nabi, salah satunya adalah gemar membaca Al-Qur`an. Adapun yang dimaksud adalah...<\/p>",
        "jawaban_a": "<p>Adam<\/p>",
