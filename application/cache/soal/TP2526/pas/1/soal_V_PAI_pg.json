        "kelas_cls": "V",
        "matapel_cls": "PAI",
        "jenis_penilaian": "pas",
        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Sesampainya Nabi Muhammad dan sahabat di Makkah rombongan langsung melaksanakan tawaf. Bilal bin Rabah mengumandangkan azan di atas puncak ka`bah.<\/p><p>Peristiwa ini sebagai tanda...<\/p>",
        "jawaban_a": "<p>Penguasaan kota Makkah oleh kaum muslimin<\/p>",
        "jawaban_b": "<p>Terbukanya kota Makkah untuk kaum muslimim<\/p>",
        "jawaban_c": "<p>Kota Makkah telah diambil alih oleh Nabi Muhammad<\/p>",
        "jawaban_d": "<p>Kota Makkah diserahkan kepada Nabi Muhammad<\/p>",
        "jawaban_e": null,
        "kunci_jawaban": "a",
        "img_path": null,
        "bank_soal_id": "149",
