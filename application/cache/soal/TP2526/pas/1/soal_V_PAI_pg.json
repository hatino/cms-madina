    },
    {
        "id": "4159",
        "thnajaran_cls": "TP2526",
        "semester": "1",
        "kelas_cls": "V",
        "matapel_cls": "PAI",
        "jenis_penilaian": "pas",
        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Pada peristiwa Haji Wada Nabi Muhammad berpesan yang sangat menyentuh hati. Salah satunya adalah pesan agar hidup berdampingan dan tidak permusuhan.<\/p><p>Berdasarkan peristiwa tersebut sikap anak muslim adalah...<\/p>",
        "jawaban_a": "<p>Berteman dengan seagama saja<\/p>",
        "jawaban_b": "<p>Mengerjakan ibadah haji setiap tahun<\/p>",
        "jawaban_c": "<p>Bersyukur karena dapat berangkat haji<\/p>",
        "jawaban_d": "<p>Menerima perbedaan yang ada di nusantara<\/p>",
        "jawaban_e": null,
        "kunci_jawaban": "d",
        "img_path": null,
        "bank_soal_id": "149",
