        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Baca wacana ieu di handap.<\/p><p>Cara nyieun ali agram teh kieu. Tipung beas dikucuran ku cai gula beureum. Diaduk serta dipadetkeun nepi ka rata. Dijieunna buleud serta bolong di tengahna, seperti ali atawa cincin. Nu matak sok disebut ali agrem. Tuluy digoreng nepi ka asak. Ali agram mibanda warna tekstur kacoklat-coklatan, sabab digorengna ngahaja rada tutung. Rasana amis, ngeunah, tur ngepros diluarna tapi dijerona mah empuk kacida.<\/p><p>Nurutkeun wacana di luhur, disebut ali agrem teh ku sebab wangunna...<\/p>",
        "jawaban_a": "<p>Buleud siga geulang<\/p>",
        "jawaban_b": "<p>Buleud siga cincin<\/p>",
        "jawaban_c": "<p>Buleud siga bal<\/p>",
        "jawaban_d": "<p>Buleud siga bal beklen<\/p>",
        "jawaban_e": null,
        "kunci_jawaban": "b",
        "img_path": null,
        "bank_soal_id": "148",
        "register_user": "guru",
        "register_date": "2025-11-17 18:07:46",
        "last_user": "guru",
        "last_update": "2025-11-27 09:27:46"
