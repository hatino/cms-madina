        "no_kd": null,
        "pertanyaan": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">UUD 1945 disahkan oleh Panitia Persiapan Kemerdekaan Indonesia (PPKI). Pengesahan ini dilakukan dalam sidang pertama PPKI, yang merupakan langkah krusial dalam pembentukan dasar hukum negara Republik Indonesia yang baru merdeka., tanggal berapakah UUD 1945 disahkan dan ditetapkan menjadi Konstitusi tertulis bangsa Indonesia...<\/span><\/p>",
        "jawaban_a": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">17 Agustus 1945<\/span><\/p>",
        "jawaban_b": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">18 Agustus 1945<\/span><\/p>",
        "jawaban_c": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">20 Agustus 1945<\/span><\/p>",
