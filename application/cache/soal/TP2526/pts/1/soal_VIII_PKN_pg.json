        "semester": "1",
        "kelas_cls": "VIII",
        "matapel_cls": "PKN",
        "jenis_penilaian": "pts",
        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Sila Keadilan Sosial bagi Seluruh Rakyat Indonesia memberikan makna bahwa dalam penyelenggaraan negara harus mengutamakan nilai keadilan sosial demi terciptanya kehidupan seluruh rakyat Indonesia yang makmur dan sejahtera<\/p><p>Amanat tersebut dijelaskan dalam pasal...<\/p>",
        "jawaban_a": "<p>P<span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">asal 34<\/span><\/p>",
        "jawaban_b": "<p>P<span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">asal 35<\/span><\/p>",
        "jawaban_c": "<p>P<span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">asal 36<\/span><\/p>",
        "jawaban_d": "<p>P<span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">asal 37<\/span><\/p>",
        "jawaban_e": null,
        "kunci_jawaban": "a",
