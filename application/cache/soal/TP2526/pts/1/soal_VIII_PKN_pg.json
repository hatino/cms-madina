        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Dasar negara Pancasila tidak bisa diganti dengan dasar negara lain, karena Pancasila mengandung nilai yang berasal dari...<\/p>",
        "jawaban_a": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Bangsa Indonesia dan bangsa lain&nbsp;<\/span><\/p>",
        "jawaban_b": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Bangsa Indonesia sendiri<\/span><\/p>",
        "jawaban_c": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Warisan penjajah<\/span><\/p>",
        "jawaban_d": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Pemberian negara lain<\/span><\/p>",
