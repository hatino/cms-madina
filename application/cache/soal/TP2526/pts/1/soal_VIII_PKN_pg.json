        "jenis_penilaian": "pts",
        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Bangsa Indonesia bukan bangsa atheis, melainkan bangsa yang percaya pada Tuhan Yang Maha Esa. Hal tersebut sesuai dengan nilai Pancasila sebagai dasar negara dan pandangan hidup bangsa Indonesia, yaitu..<\/p>",
        "jawaban_a": "<p>Nilai religius&nbsp;<\/p>",
        "jawaban_b": "<p>Nilai moral&nbsp;<\/p>",
        "jawaban_c": "<p>Nilai keadilan&nbsp;<\/p>",
        "jawaban_d": "<p>Nilai kerakyatan&nbsp;<\/p>",
        "jawaban_e": null,
        "kunci_jawaban": "a",
