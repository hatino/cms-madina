        "pertanyaan": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Salah satu tujuan negara Indonesia yang terdapat dalam Pembukaan UUD 1945, adalah ....<\/span><\/p>",
        "jawaban_a": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Kemerdekaan milik bangsa yang tidak ingin berjuang&nbsp;<\/span><\/p>",
        "jawaban_b": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Berkehidupan kebangsaan yang bebas<\/span><\/p>",
        "jawaban_c": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Penjajahan harus dibantu<\/span><\/p>",
        "jawaban_d": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Mencerdaskan kehidupan bangsa<\/span><\/p>",
