        "no_kd": null,
        "pertanyaan": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Istilah Pancasila pertama kali muncul dalam sidang BPUPKI pada tanggal ....<\/span><\/p>",
        "jawaban_a": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">17 Agustus 1946<\/span><\/p>",
        "jawaban_b": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">30 Juni 1947<\/span><\/p>",
