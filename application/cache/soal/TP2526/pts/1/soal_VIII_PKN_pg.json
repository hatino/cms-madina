        "pertanyaan": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Secara bahasa, ideologi berasal dari kata<\/span> <i>idea <\/i><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">yang berarti..... dan <\/span><i>logos<\/i><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\"><i> <\/i>yang berarti....<\/span><\/p>",
        "jawaban_a": "<p>Cita-cita dan Ilmu<\/p>",
        "jawaban_b": "<p>Arahan dan Ilmu&nbsp;<\/p>",
