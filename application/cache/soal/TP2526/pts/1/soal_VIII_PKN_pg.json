        "jenis_penilaian": "pts",
        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Berikut adalah fungsi dan peran Pancasila, <i>kecuali...<\/i><\/p>",
        "jawaban_a": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Sebagai pandangan hidup bangsa Indonesia<\/span><\/p>",
        "jawaban_b": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Sebagai kepribadian Bangsa<\/span><\/p>",
        "jawaban_c": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Sebagai sumber dari segala sumber hukum<\/span><\/p>",
        "jawaban_d": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Sebagai pelindung kekuasaan penguasa<\/span><\/p>",
