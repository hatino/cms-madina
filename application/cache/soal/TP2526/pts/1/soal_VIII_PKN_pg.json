        "jenis_penilaian": "pts",
        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Perwujudan sikap positif penerapan nilai-nilai Pancasila di lingkungan masyarakat, yaitu ....<\/span><\/p>",
        "jawaban_a": "<p>Memperlakukan sesama manusia sesuai harkat dan martabatnya<\/p>",
        "jawaban_b": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Tidak mengutamakan kebersamaan&nbsp;<\/span><\/p>",
        "jawaban_c": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Selalu menghindari semua kegiatan kemasyarakatan<\/span><\/p>",
        "jawaban_d": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Menganggap dirinya bukan bagian dari umat manusia<\/span><\/p>",
