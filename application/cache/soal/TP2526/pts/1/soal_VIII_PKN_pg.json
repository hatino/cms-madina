        "matapel_cls": "PKN",
        "jenis_penilaian": "pts",
        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Pasal 29 ayat (1) UUD NRI Tahun 1945 ditegaskan bahwa negara berdasar Ketuhanan Yang Maha Esa.<\/p><p>Pasal tersebut menjelaskan tentang sila ke...<\/p>",
        "jawaban_a": "<p>Kesatu<\/p>",
        "jawaban_b": "<p>Kedua<\/p>",
        "jawaban_c": "<p>Ketiga<\/p>",
        "jawaban_d": "<p>Keempat&nbsp;<\/p>",
        "jawaban_e": null,
        "kunci_jawaban": "a",
        "img_path": null,
