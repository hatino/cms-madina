        "no_kd": null,
        "pertanyaan": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Apa makna dari Proklamasi Kemerdekaan Indonesia bagi bangsa Indonesia...<\/span><\/p>",
        "jawaban_a": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Proklamasi Kemerdekaan Indonesia memiliki makna penting sebagai simbol kemerdekaan dan kedaulatan bangsa Indonesia dari penjajahan<",
        "jawaban_b": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Proklamasi Kemerdekaan Indonesia adalah peristiwa sejarah yang tidak memiliki arti penting bagi bangsa Indonesia<\/span><\/p>",
        "jawaban_c": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Proklamasi Kemerdekaan Indonesia hanya merupakan<strong> <\/strong>formalitas belaka tanpa makna yang sebenarnya<\/span><\/p>",
        "jawaban_d": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Proklamasi Kemerdekaan Indonesia hanyalah upaya untuk mengejar popularitas tanpa dampak yang signifikan<\/span><\/p>",
