        "pertanyaan": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Panitia sembilan kembali bertemu dan menghasilkan rumusan dasar negara Republik Indonesia yang kemudian ditetapkan pada tanggal 22 Juni 1945<strong>,<\/strong> yang disebut dengan....<\/span><\/p>",
        "jawaban_a": "<p>Piagam Jakarta<i> (Jakarta Charter)<\/i><\/p>",
        "jawaban_b": "<p>Naskah Proklamasi&nbsp;<\/p>",
        "jawaban_c": "<p>Pancasila&nbsp;<\/p>",
