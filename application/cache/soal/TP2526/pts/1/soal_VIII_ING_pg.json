        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Monita's story<\/p><p>I am Monita , &nbsp;my school held an Independence Day celebration event. It<br>welcomed students from every grade to participate in many fun<br>games, such as tug of war, krupuk race, sack race, tandem race,<br>and the marble in spoon race. Many students participated, which<br>made all the games so exciting.<\/p><p>What was the story about?<\/p>",
        "jawaban_a": "<p>Independence Day celebration in Indonesia.<\/p>",
        "jawaban_b": "<p>Independence Day celebration in Monita\u2019s school.<\/p>",
        "jawaban_c": "<p>Independence Day celebration in Monitas\u2019 hometown.<\/p>",
        "jawaban_d": "<p>Independence Day celebration in other School.<\/p>",
        "jawaban_e": null,
        "kunci_jawaban": "b",
