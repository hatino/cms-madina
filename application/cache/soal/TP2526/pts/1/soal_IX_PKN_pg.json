        "jawaban_b": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Persatuan dalam Keragaman<\/span><\/p>",
        "jawaban_c": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Persatuan dalam keragaman dan Keragaman dalam persatuan<\/span><\/p>",
