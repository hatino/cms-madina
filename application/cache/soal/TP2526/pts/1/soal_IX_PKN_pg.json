        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Hubungan Pancasila dengan UUD NRI Tahun 1945 disebutkan dalam pernyataan&nbsp; yang benar di bawah ini, <\/span>kecuali<span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\"> \u2026<\/span><\/p>",
        "jawaban_a": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Pancasila berkedudukan lebih tinggi dari UUD NRI Tahun 1945<\/span><\/p>",
        "jawaban_b": "<p>Pancasila menjadi dasar penyelenggaraan peraturan perundangan<\/p>",
        "jawaban_c": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Dalam Pembukaan UUD NRI Tahun 1945 tidak<strong> <\/strong>memuat teks Pancasila<\/span><\/p>",
        "jawaban_d": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\">Sila-sila Pancasila dijabarkan dalam pasal \u2013 pasal UUD NRI Tahun 1945<\/span><\/p>",
