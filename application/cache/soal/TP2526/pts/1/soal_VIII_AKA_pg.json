        "jenis_penilaian": "pts",
        "tema_cls": null,
        "no_kd": null,
        "pertanyaan": "<p>Bayu sering melihat temannya membawa barang-barang mewah. Namun, ia tidak merasa iri karena menghargai apa yang dimilikinya. Sikap Bayu mencerminkan konsep...<\/p>",
        "jawaban_a": "<p>Tawakkal<\/p>",
        "jawaban_b": "<p>Sabar<\/p>",
        "jawaban_c": "<p>Ikhtiar<\/p>",
        "jawaban_d": "<p>Qana'ah<\/p>",
